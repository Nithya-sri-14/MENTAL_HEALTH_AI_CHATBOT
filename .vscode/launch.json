{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Full Stack (run.py)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Launch FastAPI Backend",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Launch Streamlit Frontend",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "frontend/app.py",
        "--server.port",
        "8501"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
